# =============================================================================
# PlatformIO
# =============================================================================
# Build output, compiled firmware, and downloaded library dependencies.
# All are fully reproducible from platformio.ini + source.
.pio/

# =============================================================================
# Credentials — NEVER commit
# =============================================================================
# Contains WIFI_SSID, WIFI_PASSWORD, INFLUXDB_TOKEN, MQTT_USER, MQTT_PASS, etc.
# See the secrets template in CLAUDE.md for the required macro names.
src/secrets.h

# =============================================================================
# KiCad
# =============================================================================
# Automatic backup archives written by KiCad on every save — not source of truth.
docs/kicad/*-backups/

# Footprint info cache — regenerated by KiCad on open.
docs/kicad/fp-info-cache

# ERC/DRC reports — generated on each run via KiCad GUI or scripting.
docs/kicad/report.txt
docs/kicad/*.rpt

# Auto-save directory written during editing sessions.
docs/kicad/#auto_saved_files#

# Crash-recovery schematic written while KiCad is open.
docs/kicad/_autosave-*.kicad_sch

# Per-machine local project settings (window geometry, last-opened paths, etc.).
# Shared project settings live in .kicad_pro; .kicad_prl is machine-local.
docs/kicad/*.kicad_prl

# Per-file schematic and PCB backups (written alongside the source file).
*.kicad_sch-bak
*.kicad_pcb-bak
*.bak
*.bck

# Netlist and autorouter exports (regenerated from schematic/layout).
*.net
*.dsn
*.ses

# Tilde-prefixed lock/temp files KiCad creates.
~*

# =============================================================================
# Python
# =============================================================================
# Bytecode cache — covers .pyc, .pyo, .pyd, .pyz.
__pycache__/
*.py[codz]

# Virtual environments.
.env
venv/
.venv/
env/

# Test and type-checker caches.
.pytest_cache/
.mypy_cache/

# Packaging artifacts.
*.egg-info/

# =============================================================================
# VS Code
# =============================================================================
.vscode/

# =============================================================================
# OS / editor noise
# =============================================================================
.DS_Store
Thumbs.db
*.swp
*.swo
.claude/settings.local.json
