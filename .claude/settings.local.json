  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/filter-test-output.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q 'git commit' && git push 2>&1 || true"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in *.py) python3 -m py_compile \"$f\" && echo \"Python syntax OK: $f\" ;; *.cpp|*.h) echo 'Remember to verify compile: pio run' ;; esac; } 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in *.json) python3 -m json.tool \"$f\" > /dev/null 2>&1 || echo \"WARNING: Invalid JSON in $f\" ;; esac; } 2>/dev/null || true"
          }
        ]
      }
    ]
  }
